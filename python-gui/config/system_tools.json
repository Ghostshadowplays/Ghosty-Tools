    {
      "id": "winget",
      "name": "Windows Package Manager (winget)",
      "description": "Update or install Windows Package Manager (winget) - the official Windows package manager.",
      "category": "Package Managers",
      "requires_admin": false,
      "requires_restart": false,
      "check_command": "winget --version",
      "install_commands": [
        "Add-AppxPackage -RegisterByFamilyName -MainPackage Microsoft.DesktopAppInstaller_8wekyb3d8bbwe"
      ],
      "post_install_message": "Winget updated successfully! Winget is now ready to install and manage packages."
    },
    {
      "id": "chocolatey",
      "name": "Chocolatey Package Manager",
      "description": "Install Chocolatey, a popular package manager for Windows with thousands of packages.",
      "category": "Package Managers",
      "requires_admin": true,
      "requires_restart": false,
      "check_command": "choco --version",
      "install_commands": [
        "Set-ExecutionPolicy Bypass -Scope Process -Force; [System.Net.ServicePointManager]::SecurityProtocol = [System.Net.ServicePointManager]::SecurityProtocol -bor 3072; iex ((New-Object System.Net.WebClient).DownloadString('https://community.chocolatey.org/install.ps1'))"
      ],
      "post_install_message": "Chocolatey installed successfully! Restart your terminal and use 'choco' command to manage packages."
    },
