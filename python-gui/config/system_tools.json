{
  "version": "1.0",
  "description": "System Tools Installation Configuration",
  "tools": [
    {
      "id": "wsl",
      "name": "Windows Subsystem for Linux (WSL)",
      "description": "Install WSL 2 for running Linux distributions on Windows. Enables seamless Linux development environment.",
      "category": "Development Environment",
      "requires_admin": true,
      "requires_restart": true,
      "check_command": "wsl --status",
      "install_commands": [
        "dism.exe /online /enable-feature /featurename:Microsoft-Windows-Subsystem-Linux /all /norestart",
        "dism.exe /online /enable-feature /featurename:VirtualMachinePlatform /all /norestart",
        "wsl --set-default-version 2"
      ],
      "post_install_message": "WSL installed successfully! A restart is required. After restarting, install a Linux distribution from the Microsoft Store (e.g., Ubuntu)."
    },
    {
      "id": "git",
      "name": "Git for Windows",
      "description": "Install Git version control system with Git Bash, Git GUI, and shell integration.",
      "category": "Development Tools",
      "requires_admin": false,
      "requires_restart": false,
      "check_command": "git --version",
      "install_commands": [
        "winget install --id Git.Git -e --source winget --accept-package-agreements --accept-source-agreements"
      ],
      "post_install_message": "Git installed successfully! You may need to restart your terminal or IDE to use git commands."
    },
    {
      "id": "python",
